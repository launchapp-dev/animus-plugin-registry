{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/launchapp-dev/animus-plugin-registry/raw/main/schema.json",
  "title": "Animus Plugin Registry",
  "description": "Schema for the Animus plugin registry index (plugins.json).",
  "type": "object",
  "required": ["registry_version", "updated_at", "plugins"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to the schema document."
    },
    "registry_version": {
      "type": "string",
      "description": "Semantic version of the registry schema.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of the last registry update.",
      "format": "date-time"
    },
    "plugins": {
      "type": "array",
      "description": "List of known Animus plugins.",
      "items": {
        "$ref": "#/$defs/plugin"
      }
    }
  },
  "$defs": {
    "plugin": {
      "type": "object",
      "required": [
        "name",
        "kind",
        "repo",
        "latest_tag",
        "description",
        "license",
        "install_hint"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique plugin name (typically matches the repo name).",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
        },
        "kind": {
          "type": "string",
          "description": "Plugin kind.",
          "enum": ["subject_backend", "provider", "trigger_backend"]
        },
        "repo": {
          "type": "string",
          "description": "GitHub repository in <owner>/<name> form.",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "latest_tag": {
          "type": "string",
          "description": "Latest released tag (e.g. v0.1.0).",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
        },
        "description": {
          "type": "string",
          "description": "Short human-readable description.",
          "minLength": 1
        },
        "homepage": {
          "type": "string",
          "description": "Optional homepage or repo URL.",
          "format": "uri"
        },
        "license": {
          "type": "string",
          "description": "SPDX license identifier (e.g. MIT, Apache-2.0).",
          "minLength": 1
        },
        "stability": {
          "type": "string",
          "description": "Stability tier.",
          "enum": ["alpha", "beta", "stable"]
        },
        "platforms": {
          "type": "array",
          "description": "Rust target triples with prebuilt release artifacts.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "tags": {
          "type": "array",
          "description": "Free-form discoverability tags.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "install_hint": {
          "type": "string",
          "description": "Suggested CLI command to install this plugin.",
          "minLength": 1
        }
      }
    }
  }
}
